# Chrome Web Store upload settings.
# Copy to your shell environment; do not put real secrets in git.
CWS_PUBLISHER_ID=
CWS_ITEM_ID=
CWS_CLIENT_ID=
CWS_CLIENT_SECRET=
CWS_REFRESH_TOKEN=

# Optional: defaults to release/chattree-chrome-v<package.version>.zip
CWS_PACKAGE_PATH=

# Optional: set to 1 only after Store Listing, Privacy, Distribution, and Test Instructions are complete.
CWS_PUBLISH_AFTER_UPLOAD=0
